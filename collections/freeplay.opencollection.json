        {
          "info": {
            "name": "Create a version by template ID",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://app.freeplay.ai/api/v2/projects/{{projectId}}/prompt-templates/id/{{templateId}}/versions",
