        {
          "info": {
            "name": "Assign a version to environments",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://app.freeplay.ai/api/v2/projects/{{projectId}}/prompt-templates/id/{{templateId}}/versions/{{versionId}}/environments",
            "body": {
              "type": "json",
              "data": "{}"
